#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

%:
	dh $@

override_dh_auto_clean:
	# Nothing to clean - files are copied via debian/install

override_dh_auto_build:
	# Frontend is built before packaging; backend is copied via debian/install.
	# Generate requirements-prod.txt (runtime-only deps) so debian/install can
	# ship it and the postinst can build the venv from it.  The full
	# requirements.txt carries dev tooling (pylint/astroid/pytest/playwright)
	# which is NOT in the air-gap wheel set, so installing it offline fails.
	python3 scripts/update-requirements-prod.py
	# Stamp the package version into backend/__init__.py so backend.__version__
	# resolves at runtime (server-info + federation "Reported version" show it
	# instead of "unknown").  Strip the Debian revision suffix (e.g. -1).
	printf '__version__ = "%s"\n' "$$(dpkg-parsechangelog -S Version | sed 's/-[^-]*$$//')" > backend/__init__.py

override_dh_auto_test:
	# Skip tests during package build

override_dh_auto_install:
	# Files are installed via debian/install file
	dh_auto_install

override_dh_installinit:
	dh_installinit --name=sysmanage --no-start

override_dh_installsystemd:
	dh_installsystemd --name=sysmanage --no-start --no-enable
