# Lintian overrides for the sysmanage source package.
#
# Both entries below are justified — the bundled artifacts have
# upstream source available in the same repo (just not in the form
# lintian's heuristic looks for), and we ship them pre-built to keep
# Launchpad's build farm out of the JavaScript / Windows toolchain
# business.

# Minified vite output.  Upstream source lives in ``frontend/src/`` in
# the same repository (the .ts/.tsx files vite compiles); we ship the
# pre-built ``frontend/dist/assets/*`` because the Launchpad build
# environment doesn't have a node/npm toolchain installed, and pulling
# one in just to re-run ``vite build`` triples build time for no
# functional difference.  The .js.map sidecar files are present in the
# same directory for anyone who wants to inspect the un-minified
# output.  Lintian's ``source-is-missing`` heuristic doesn't look at
# those — hence the override.
sysmanage source: source-is-missing frontend/dist/assets/*

# nssm.exe is a third-party Windows service-supervisor binary
# (https://nssm.cc/, public domain license).  We vendor it unmodified
# under ``installer/windows/nssm/`` to install sysmanage as a Windows
# service on .msi-installed deployments.  Building nssm from source
# requires the Visual Studio toolchain on Windows, which is
# fundamentally not reproducible from a Debian source package — the
# binary is pinned by SHA256 in the upstream README to give consumers
# verification ammunition.  This file is never executed or shipped on
# Linux; it is only used by the Windows .msi builder path elsewhere
# in the repository.  Upstream: https://git.nssm.cc/nssm/nssm.
sysmanage source: source-contains-prebuilt-windows-binary installer/windows/nssm/nssm.exe
