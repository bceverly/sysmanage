---
# SysManage Server Configuration
#
# This file should be copied to /etc/sysmanage.yaml and customized for
# your environment.
#
# For a fully-populated example with every option, see the canonical
# template at the top of the source tree (sysmanage.yaml.example) or
# the online config builder at https://sysmanage.org/config-builder.html

# Backend HTTP API.  Nginx (port 3000) reverse-proxies /api/* and /ws to
# this socket.  Keep host=localhost — every backend route now lives under
# /api so external clients reach the backend only through nginx; there's
# no reason to expose the raw uvicorn port.
api:
  host: "localhost"
  port: 8080

# Database connection (PostgreSQL required).
database:
  user: "sysmanage"
  password: "CHANGE_ME_IN_PRODUCTION"   # ⚠ change this
  host: "localhost"
  port: 5432
  name: "sysmanage"
  # Optional: ssl_mode: "prefer"  # disable|allow|prefer|require|verify-ca|verify-full

# Authentication and JWT signing.
security:
  password_salt: "CHANGE_ME_IN_PRODUCTION_USE_RANDOM_STRING"   # ⚠ change this
  admin_userid: "admin"
  admin_password: "admin"   # ⚠ change this on first login
  jwt_secret: "CHANGE_ME_IN_PRODUCTION_USE_RANDOM_SECRET"   # ⚠ change this
  jwt_algorithm: "HS256"
  jwt_auth_timeout: 600
  jwt_refresh_timeout: 60000

# Web UI host/port.  Nginx serves the static frontend on this port and
# reverse-proxies /api/* to the backend on api.port above.
webui:
  host: "localhost"
  port: 3000

logging:
  level: "INFO"   # DEBUG | INFO | WARNING | ERROR | CRITICAL
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Multi-tenancy (Phase 13.1) — OPT-IN. Leave disabled for single-tenant /
# homelab / on-prem installs (the default: one implicit tenant). Enable only to
# run a SaaS control plane hosting isolated tenants (one database per tenant).
# See the canonical sysmanage.yaml.example for the accompanying registry: and
# backup: blocks that go with SaaS mode.
multitenancy:
  enabled: false
  self_service_provisioning: false

# Pro+ license (optional — leave key empty for the Community Edition)
license:
  key: ""
  phone_home_url: "https://license.sysmanage.io"
  phone_home_interval_hours: 24
  modules_path: "/var/lib/sysmanage/modules"

# OpenBAO / Vault integration (optional)
# openbao:
#   enabled: false
#   address: "http://localhost:8200"
#   token: ""

# OpenTelemetry (optional)
# telemetry:
#   enabled: false
#   endpoint: "http://localhost:4317"
