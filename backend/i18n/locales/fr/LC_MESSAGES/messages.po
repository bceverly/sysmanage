# LXD Container Management strings
#: backend/api/child_host_virtualization_enable.py:213
msgid "LXD is only supported on Linux hosts"
msgstr "LXD n'est pris en charge que sur les hôtes Linux"

#: backend/api/child_host_virtualization_enable.py:221
msgid "Agent must be running with root privileges to initialize LXD"
msgstr "L'agent doit s'exécuter avec les privilèges root pour initialiser LXD"

#: backend/api/child_host_virtualization_enable.py:235
msgid "LXD initialization requested"
msgstr "Initialisation de LXD demandée"

#: backend/api/child_host_virtualization_enable.py:243
msgid ""
"LXD initialization requested. The agent will install and configure LXD "
"automatically."
msgstr ""
"Initialisation de LXD demandée. L'agent va installer et configurer LXD "
"automatiquement."

#: backend/api/child_host_virtualization_enable.py:276
msgid "VMM is only supported on OpenBSD hosts"
msgstr "VMM n'est pris en charge que sur les hôtes OpenBSD"

#: backend/api/child_host_virtualization_enable.py:284
msgid "Agent must be running with root privileges to initialize VMM"
msgstr "L'agent doit s'exécuter avec les privilèges root pour initialiser VMM"

#: backend/api/child_host_virtualization_enable.py:298
msgid "VMM initialization requested"
msgstr "Initialisation de VMM demandée"

#: backend/api/child_host_virtualization_enable.py:306
msgid ""
"VMM initialization requested. The agent will enable and start the vmd "
"daemon."
msgstr ""
"Initialisation de VMM demandée. L'agent va activer et démarrer le daemon "
"vmd."

#: backend/api/child_host_virtualization_enable.py:348
msgid "Agent must be running with root privileges to initialize KVM"
msgstr "L'agent doit s'exécuter avec les privilèges root pour initialiser KVM"

#: backend/api/child_host_virtualization_enable.py:362
msgid "KVM initialization requested"
msgstr "Initialisation de KVM demandée"

#: backend/api/child_host_virtualization_enable.py:370
msgid ""
"KVM initialization requested. The agent will install libvirt and configure "
"KVM for virtual machine management."
msgstr ""
"Initialisation de KVM demandée. L'agent installera libvirt et configurera "
"KVM pour la gestion des machines virtuelles."

#: backend/api/child_host_virtualization_enable.py:403
#: backend/api/child_host_virtualization_enable.py:467
msgid "bhyve is only supported on FreeBSD hosts"
msgstr "Le bhyve n'est pris en charge que sur les hotes FreeBSD"

#: backend/api/child_host_virtualization_enable.py:411
msgid "Agent must be running with root privileges to initialize bhyve"
msgstr ""
"L'agent doit être exécuté avec des privilèges root pour initialiser bhyve"

#: backend/api/child_host_virtualization_enable.py:425
msgid "bhyve initialization requested"
msgstr "Initialisation du bhyve demandée"

#: backend/api/child_host_virtualization_enable.py:433
msgid ""
"bhyve initialization requested. The agent will load vmm.ko and configure the"
" system for bhyve virtual machines."
msgstr ""
"Initialisation du bhyve demandée. L'agent chargera vmm.ko et configurera le "
"système pour les machines virtuelles bhyve."

#: backend/api/child_host_virtualization_enable.py:474
msgid "Agent must be running with root privileges to disable bhyve"
msgstr ""
"L'agent doit être exécuté avec des privilèges root pour désactiver bhyve"

#: backend/api/child_host_virtualization_enable.py:487
msgid "bhyve disable requested"
msgstr "Désactivation du bhyve demandée"

#: backend/api/child_host_virtualization_enable.py:495
msgid ""
"bhyve disable requested. The agent will unload vmm.ko and update the system "
"configuration. This will fail if any VMs are running."
msgstr ""
"Désactivation du bhyve demandée. L'agent déchargera vmm.ko et mettra à jour "
"la configuration du système. Cette opération échouera si des machines "
"virtuelles sont en cours d'exécution."

#: backend/api/child_host_virtualization_enable.py:536
msgid "Agent must be running with root privileges to enable KVM modules"
msgstr ""
"L'agent doit être exécuté avec des privilèges root pour activer les modules "
"KVM"

#: backend/api/child_host_virtualization_enable.py:550
msgid "KVM modules enable requested"
msgstr "Activation des modules KVM demandée"

#: backend/api/child_host_virtualization_enable.py:558
msgid ""
"KVM modules enable requested. The agent will load the KVM kernel modules via"
" modprobe."
msgstr ""
"Activation des modules KVM demandée. L'agent chargera les modules noyau KVM "
"via modprobe."

#: backend/api/child_host_virtualization_enable.py:600
msgid "Agent must be running with root privileges to disable KVM modules"
msgstr ""
"L'agent doit être exécuté avec des privilèges root pour désactiver les "
"modules KVM"

#: backend/api/child_host_virtualization_enable.py:614
msgid "KVM modules disable requested"
msgstr "Désactivation des modules KVM demandée"

#: backend/api/child_host_virtualization_enable.py:622
msgid ""
"KVM modules disable requested. The agent will unload the KVM kernel modules "
"via modprobe -r. This will fail if any VMs are running."
msgstr ""
"Désactivation des modules KVM demandée. L'agent déchargera les modules noyau"
" KVM via modprobe -r. Cela échouera si des VM sont en cours d'exécution."

