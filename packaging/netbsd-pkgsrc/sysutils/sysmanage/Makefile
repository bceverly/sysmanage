# Phase 11.8 pkgsrc-wip submission stub — sysmanage (server).
# ``DISTNAME`` and ``GITHUB_TAG`` are sed-replaced from ``0.0.0`` /
# ``v0.0.0`` to the release tag value by the ``netbsd-pkgsrc`` job in
# .github/workflows/build-and-release.yml.  Do not hand-edit on release.
# ``distinfo`` (BLAKE2s + SHA512 + Size) is regenerated by the same job.

DISTNAME=	sysmanage-0.0.0
CATEGORIES=	sysutils python
MASTER_SITES=	${MASTER_SITE_GITHUB:=bceverly/sysmanage/}
GITHUB_TAG=	v0.0.0
EXTRACT_SUFX=	.tar.gz

MAINTAINER=	bryan@theeverlys.com
HOMEPAGE=	https://github.com/bceverly/sysmanage/
COMMENT=	Centralized system management server with web-based interface
LICENSE=	gnu-agpl-v3

WRKSRC=		${WRKDIR}/sysmanage-${PKGVERSION_NOREV}

USE_LANGUAGES=	# none
NO_BUILD=	yes
NO_CONFIGURE=	yes
PKG_DESTDIR_SUPPORT=	user-destdir

DEPENDS+=	${PYPKGPREFIX}-aiohttp-[0-9]*:../../www/py-aiohttp
DEPENDS+=	${PYPKGPREFIX}-aiofiles-[0-9]*:../../devel/py-aiofiles
DEPENDS+=	${PYPKGPREFIX}-alembic-[0-9]*:../../databases/py-alembic
DEPENDS+=	${PYPKGPREFIX}-argon2-cffi-[0-9]*:../../security/py-argon2-cffi
DEPENDS+=	${PYPKGPREFIX}-bcrypt-[0-9]*:../../security/py-bcrypt
DEPENDS+=	${PYPKGPREFIX}-cryptography-[0-9]*:../../security/py-cryptography
DEPENDS+=	${PYPKGPREFIX}-defusedxml-[0-9]*:../../textproc/py-defusedxml
DEPENDS+=	${PYPKGPREFIX}-fastapi-[0-9]*:../../www/py-fastapi
DEPENDS+=	${PYPKGPREFIX}-httpx-[0-9]*:../../www/py-httpx
DEPENDS+=	${PYPKGPREFIX}-jinja2-[0-9]*:../../textproc/py-jinja2
DEPENDS+=	${PYPKGPREFIX}-mako-[0-9]*:../../textproc/py-mako
DEPENDS+=	${PYPKGPREFIX}-orjson-[0-9]*:../../devel/py-orjson
DEPENDS+=	${PYPKGPREFIX}-Pillow-[0-9]*:../../graphics/py-Pillow
DEPENDS+=	${PYPKGPREFIX}-psutil-[0-9]*:../../sysutils/py-psutil
DEPENDS+=	${PYPKGPREFIX}-psycopg2-[0-9]*:../../databases/py-psycopg2
DEPENDS+=	${PYPKGPREFIX}-pydantic-[0-9]*:../../devel/py-pydantic
DEPENDS+=	${PYPKGPREFIX}-yaml-[0-9]*:../../textproc/py-yaml
DEPENDS+=	${PYPKGPREFIX}-sqlalchemy-[0-9]*:../../databases/py-sqlalchemy
DEPENDS+=	${PYPKGPREFIX}-starlette-[0-9]*:../../www/py-starlette
DEPENDS+=	${PYPKGPREFIX}-uvicorn-[0-9]*:../../www/py-uvicorn
DEPENDS+=	${PYPKGPREFIX}-websockets-[0-9]*:../../net/py-websockets
DEPENDS+=	postgresql15-server-[0-9]*:../../databases/postgresql15-server
DEPENDS+=	nginx-[0-9]*:../../www/nginx

PYTHON_VERSIONS_INCOMPATIBLE=	27

do-install:
	${INSTALL_DATA_DIR} ${DESTDIR}${PREFIX}/libexec/sysmanage
	cd ${WRKSRC} && pax -rw backend ${DESTDIR}${PREFIX}/libexec/sysmanage/
	cd ${WRKSRC} && pax -rw alembic ${DESTDIR}${PREFIX}/libexec/sysmanage/
	${INSTALL_DATA} ${WRKSRC}/alembic.ini \
		${DESTDIR}${PREFIX}/libexec/sysmanage/alembic.ini
	${INSTALL_DATA_DIR} ${DESTDIR}${PREFIX}/share/examples/sysmanage
	${INSTALL_DATA} ${WRKSRC}/installer/opensuse/sysmanage.yaml.example \
		${DESTDIR}${PREFIX}/share/examples/sysmanage/sysmanage.yaml
	${INSTALL_DATA} ${WRKSRC}/installer/opensuse/sysmanage-nginx.conf \
		${DESTDIR}${PREFIX}/share/examples/sysmanage/sysmanage-nginx.conf

.include "../../lang/python/application.mk"
.include "../../mk/bsd.pkg.mk"
